# La pagina de inicio es la calculadora (version FREE abierta)
DirectoryIndex index.php

# URLs cortas: /login y /logout (sin .php)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^login/?$ login.php [L]
  RewriteRule ^logout/?$ logout.php [L]
</IfModule>

# No mostrar el listado de archivos de la carpeta
Options -Indexes

# Evitar que se descarguen archivos sensibles
<FilesMatch "^(config\.php|db\.php|auth\.php)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
